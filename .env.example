# Gmail credentials for the contact form
# Use a Gmail App Password (not your regular password)
# Guide: https://support.google.com/accounts/answer/185833
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Where to deliver enquiry emails (defaults to info@oxfordinternationaleducationalgroup.com)
CONTACT_EMAIL=info@oxfordinternationaleducationalgroup.com
